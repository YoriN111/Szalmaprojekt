RewriteEngine On
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# API requests -> index.php (backend router)
RewriteRule ^api/ index.php [QSA,L]

# root -> frontend app (absolute URL-path target; relative target leaks filesystem path on Windows/XAMPP)
RewriteCond %{REQUEST_URI} ^(.*)$
RewriteRule ^$ %1frontend/ [R=302,L]
